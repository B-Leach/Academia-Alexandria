{
  "name": "@academia-alexandria/database",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "seed:dev": "dotenv -e ../../.env -- tsx prisma/seed-dev.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@academia-alexandria/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.19.11",
    "bcryptjs": "^3.0.3",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@academia-alexandria/shared": "workspace:*",
    "@prisma/client": "^6.5.0"
  }
}
