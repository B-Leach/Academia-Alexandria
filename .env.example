# Database
DATABASE_URL="postgresql://alexandria:alexandria@localhost:5432/alexandria?schema=public"

# Docker Compose Postgres (only needed for docker-compose.prod.yml)
POSTGRES_USER="alexandria"
POSTGRES_PASSWORD="alexandria"
POSTGRES_DB="alexandria"

# Auth.js
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ORCID OAuth (optional)
AUTH_ORCID_ID=""
AUTH_ORCID_SECRET=""

# S3-compatible storage (MinIO for local dev)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="papers"
S3_REGION="us-east-1"

# Stripe (optional — bounty features disabled if not set)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cron job authentication
CRON_SECRET=""

# Public URL for S3 assets (used in CSP headers and PDF cover pages)
S3_PUBLIC_URL="http://localhost:9000"

# Redis (optional — falls back to in-memory rate limiting)
REDIS_URL=""

# CrossRef DOI registration (optional — DOI auto-assignment disabled if not set)
CROSSREF_USERNAME=""
CROSSREF_PASSWORD=""
CROSSREF_DOI_PREFIX=""
CROSSREF_DEPOSITOR_NAME=""
CROSSREF_DEPOSITOR_EMAIL=""

# Copyleaks plagiarism detection (optional — external check disabled if not set, internal similarity always runs)
COPYLEAKS_EMAIL=""
COPYLEAKS_API_KEY=""
COPYLEAKS_WEBHOOK_SECRET=""

# Email (optional — falls back to console logging)
RESEND_API_KEY=""
EMAIL_FROM="noreply@academiaalexandria.org"
